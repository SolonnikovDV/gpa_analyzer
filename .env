# GigaChat API — ключ вносится только вручную сюда, без сохранения через UI
# Документация: https://developers.sber.ru/docs/ru/gigachat/api/reference/rest/post-token

# Профиль «разработчик» берёт токен из .key в корне проекта (первая строка или base64).
# Альтернатива — переменные ниже:
# GIGACHAT_CREDENTIALS=ваш_base64_токен
# GIGACHAT_TOKEN=ваш_base64_токен
# GIGACHAT_CREDENTIALS=

# Или Client ID и Client Secret отдельно
# GIGACHAT_CLIENT_ID=
# GIGACHAT_CLIENT_SECRET=

# Scope: GIGACHAT_API_PERS | GIGACHAT_API_B2B | GIGACHAT_API_CORP
# GIGACHAT_SCOPE=GIGACHAT_API_PERS

# Проверка SSL (при self signed certificate — false)
GIGACHAT_VERIFY_SSL_CERTS=false